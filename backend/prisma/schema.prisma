generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ProductClass {
  code             Int       @id @map("PRODUCT_CLASS_CODE")
  productClassDesc String    @map("PRODUCT_CLASS_DESC")
  products         Product[]

  @@map("product_class")
}

model Product {
  productId            Int      @id @map("PRODUCT_ID")
  productDesc          String?  @map("PRODUCT_DESC") @db.VarChar(60)
  productClassCode     Int?     @map("PRODUCT_CLASS_CODE")
  productPrice         Decimal? @map("PRODUCT_PRICE") @db.Decimal(12, 2)
  productQuantityAvail Int?     @map("PRODUCT_QUANTITY_AVAIL")
  len                  Int?     @map("LEN")
  width                Int?     @map("WIDTH")
  height               Int?     @map("HEIGHT")
  weight               Decimal? @map("WEIGHT") @db.Decimal(10, 4)

  orderItems   OrderItem[]
  productClass ProductClass? @relation(fields: [productClassCode], references: [code])

  @@map("product")
}

model OrderHeader {
  orderId           Int       @id @default(autoincrement()) @map("ORDER_ID")
  customerId        Int?      @map("CUSTOMER_ID")
  orderDate         DateTime? @map("ORDER_DATE") @db.Date
  orderStatus       String?   @map("ORDER_STATUS") @db.VarChar(10)
  paymentMode       String?   @map("PAYMENT_MODE") @db.VarChar(20)
  paymentDate       DateTime? @map("PAYMENT_DATE") @db.Date
  orderShipmentDate DateTime? @map("ORDER_SHIPMENT_DATE") @db.Date
  shipperId         Int?      @map("SHIPPER_ID")
  shippingAddressId Int?      @map("SHIPPING_ADDRESS_ID")

  customer        User?        @relation(fields: [customerId], references: [userId])
  shippingAddress Address?     @relation(fields: [shippingAddressId], references: [addressId])
  shipper         Shipper?     @relation(fields: [shipperId], references: [shipperId])
  orderItems      OrderItem[]

  @@map("order_header")
}

model OrderItem {
  orderId         Int @map("ORDER_ID")
  productId       Int @map("PRODUCT_ID")
  productQuantity Int @map("PRODUCT_QUANTITY")

  order   OrderHeader @relation(fields: [orderId], references: [orderId])
  product Product     @relation(fields: [productId], references: [productId])

  @@id([orderId, productId])
  @@map("order_items")
}

model Shipper {
  shipperId      Int     @id @map("SHIPPER_ID")
  shipperName    String? @map("SHIPPER_NAME") @db.VarChar(30)
  shipperPhone   BigInt? @map("SHIPPER_PHONE")
  shipperAddress Int?    @map("SHIPPER_ADDRESS")

  orders OrderHeader[]

  @@map("shipper")
}

model Address {
  addressId    Int      @id @default(autoincrement()) @map("ADDRESS_ID")
  addressLine1 String?  @map("ADDRESS_LINE1") @db.VarChar(50)
  addressLine2 String?  @map("ADDRESS_LINE2") @db.VarChar(50)
  city         String?  @map("CITY") @db.VarChar(30)
  state        String?  @map("STATE") @db.VarChar(30)
  pincode      Int?     @map("PINCODE")
  country      String?  @map("COUNTRY") @db.VarChar(30)
  customerId   Int?     @map("CUSTOMER_ID")
  label        String?  @default("Home") @map("LABEL") @db.VarChar(50)
  isDefault    Boolean? @default(false) @map("IS_DEFAULT")
  isDeleted    Boolean  @default(false) @map("IS_DELETED")

  customer User?         @relation(fields: [customerId], references: [userId])
  orders   OrderHeader[]

  @@map("address")
}

model User {
  userId    Int       @id @default(autoincrement()) @map("USER_ID")
  username  String    @unique @map("USERNAME") @db.VarChar(50)
  email     String    @unique @map("EMAIL") @db.VarChar(100)
  password  String    @map("PASSWORD") @db.VarChar(255)
  role      UserRole? @default(user) @map("ROLE")
  createdAt DateTime? @default(now()) @map("CREATED_AT") @db.Timestamp(0)

  addresses Address[]
  orders    OrderHeader[]

  @@map("users")
}

enum UserRole {
  user
  admin

  @@map("users_ROLE")
}