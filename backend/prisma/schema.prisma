generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ProductClass {
  code             Int       @id @map("PRODUCT_CLASS_CODE")
  productClassDesc String    @map("PRODUCT_CLASS_DESC")
  products         Product[] @relation()

  @@map("product_class")
}


model Product {
  productId        Int      @id @map("PRODUCT_ID")
  productDesc      String?  @map("PRODUCT_DESC") @db.VarChar(60)
  productClassCode Int?     @map("PRODUCT_CLASS_CODE")
  productPrice     Decimal? @map("PRODUCT_PRICE") @db.Decimal(12, 2)
  productQuantityAvail Int? @map("PRODUCT_QUANTITY_AVAIL")
  LEN              Int?
  WIDTH            Int?
  HEIGHT           Int?
  WEIGHT           Decimal? @db.Decimal(10, 4)

  orderItems OrderItem[]
  productClass ProductClass? @relation(fields: [productClassCode], references: [code])

  @@map("product")
}

model OrderHeader {
  orderId           Int       @id @default(autoincrement()) @map("ORDER_ID")
  customerId        Int?      @map("CUSTOMER_ID")
  orderDate         DateTime? @map("ORDER_DATE") @db.Date
  orderStatus       String?   @map("ORDER_STATUS") @db.VarChar(10)
  paymentMode       String?   @map("PAYMENT_MODE") @db.VarChar(20)
  paymentDate       DateTime? @map("PAYMENT_DATE") @db.Date
  orderShipmentDate DateTime? @map("ORDER_SHIPMENT_DATE") @db.Date
  shipperId         Int?      @map("SHIPPER_ID")
  shippingAddressId Int?      @map("SHIPPING_ADDRESS_ID")

  shippingAddress address? @relation(fields: [shippingAddressId], references: [ADDRESS_ID])

  orderItems OrderItem[]
  shipper    Shipper?   @relation(fields: [shipperId], references: [shipperId])

  @@map("order_header")
}

model OrderItem {
  orderId         Int @map("ORDER_ID")
  productId       Int @map("PRODUCT_ID")
  productQuantity Int? @map("PRODUCT_QUANTITY")

  order   OrderHeader @relation(fields: [orderId], references: [orderId])
  product Product     @relation(fields: [productId], references: [productId])

  @@id([orderId, productId])   // ✅ composite PK
  @@map("order_items")
}

model Shipper {
  shipperId      Int    @id @map("SHIPPER_ID")
  shipperName    String? @map("SHIPPER_NAME") @db.VarChar(30)
  shipperPhone   BigInt? @map("SHIPPER_PHONE")
  shipperAddress Int?    @map("SHIPPER_ADDRESS")

  orders OrderHeader[]

  @@map("shipper")
}

model address {
  ADDRESS_ID    Int      @id @default(autoincrement())
  ADDRESS_LINE1 String?  @db.VarChar(50)
  ADDRESS_LINE2 String?  @db.VarChar(50)
  CITY          String?  @db.VarChar(30)
  STATE         String?  @db.VarChar(30)
  PINCODE       Int?
  COUNTRY       String?  @db.VarChar(30)
  CUSTOMER_ID   Int?
  LABEL         String?  @default("Home") @db.VarChar(50)
  IS_DEFAULT    Boolean? @default(false)

  orders OrderHeader[]

  @@map("address")
}

model users {
  USER_ID    Int         @id @default(autoincrement())
  USERNAME   String      @unique(map: "USERNAME") @db.VarChar(50)
  EMAIL      String      @unique(map: "EMAIL") @db.VarChar(100)
  PASSWORD   String      @db.VarChar(255)
  ROLE       users_ROLE? @default(user)
  CREATED_AT DateTime?   @default(now()) @db.Timestamp(0)

  @@map("users")
}

enum users_ROLE {
  user
  admin
}